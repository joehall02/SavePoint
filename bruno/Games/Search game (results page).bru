meta {
  name: Search game (results page)
  type: http
  seq: 8
}

post {
  url: {{base_url}}/{{game_route}}/result?search=lego&limit=5&platform=pc&page=10
  body: none
  auth: inherit
}

params:query {
  search: lego
  limit: 5
  platform: pc
  page: 10
}

settings {
  encodeUrl: true
  timeout: 0
}
