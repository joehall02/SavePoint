meta {
  name: game count
  type: http
  seq: 5
}

post {
  url: {{igdb_base_url}}/games/count
  body: text
  auth: inherit
}

headers {
  Authorization: Bearer {{igdb_access_token}}
  Client-ID: {{igdb_client_id}}
}

body:text {
  search "lego";
  where (platforms = [12]);
}

settings {
  encodeUrl: true
  timeout: 0
}
